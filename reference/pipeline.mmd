flowchart TB
  classDef src fill:#F0D9C9,stroke:#B35A28,stroke-width:1.5px,color:#3a2208;
  classDef pub fill:#D1F1F1,stroke:#0B6E6E,stroke-width:1.5px,color:#053333;
  classDef rev fill:#E9E5DC,stroke:#5E5A50,stroke-width:1.5px,color:#2c2a24;
  classDef store fill:#ffffff,stroke:#5E5A50,stroke-width:1.3px,color:#2c2a24;

  raw@{ shape: doc, label: "Raw source" }
  ingester@{ shape: rounded, label: "Ingester" }
  ingest@{ shape: doc, label: "Ingest" }
  predigest@{ shape: doc, label: "Pre-digest" }
  archive@{ shape: docs, label: "sources/ archive" }
  workbench@{ shape: rounded, label: "Workbench" }
  digester@{ shape: rounded, label: "Digester" }
  digests@{ shape: docs, label: "Per-model digests" }
  selector@{ shape: rounded, label: "Digest selector" }
  selected@{ shape: doc, label: "Selected digest" }
  assimilator@{ shape: rounded, label: "Assimilator" }
  kg@{ shape: cyl, label: "Knowledge graph" }
  synthesiser@{ shape: rounded, label: "Synthesiser" }
  briefs@{ shape: doc, label: "Brief" }
  assembler@{ shape: rounded, label: "Assembler" }
  content@{ shape: doc, label: "Content" }
  site@{ shape: rounded, label: "Site" }
  brand@{ shape: docs, label: "Brand" }

  raw -->|"original file (1:1)"| ingester
  ingester -->|"record (1:1)"| ingest
  ingester -->|"originals + raw transcripts"| archive
  ingest -->|"deterministic prep: strip irrelevant, inline footnotes, strip timestamps"| predigest
  predigest -->|"the exact model input"| digester
  digester -->|"one digest per model (1..N)"| digests
  digests -->|"candidate digests"| selector
  selector -->|"picks the single best"| selected
  selected ==>|"one per record (1:1)"| assimilator
  assimilator <-->|"reads + updates"| kg
  kg -->|"entity + its claims"| synthesiser
  synthesiser ==>|"a brief per page (one -> many)"| briefs
  briefs -->|"the page's brief (1:1)"| assembler
  selected -->|"one record (1:1)"| assembler
  assembler -->|"entity articles + inspection pages"| content
  content -->|"renders"| site
  brand -.->|"tokens, logo"| site
  ingest <-.->|"review + corrections"| workbench
  selector <-.->|"review the selection"| workbench
  archive -.->|"check against source"| workbench
  workbench -.->|"digestible signal + visual notes"| digester

  class raw,ingest,predigest,archive src
  class ingester,digester,digests,selector,selected,assimilator,kg,synthesiser,briefs,assembler,content,site pub
  class workbench rev
  class brand store

  click raw nodeClick
  click ingester nodeClick
  click ingest nodeClick
  click predigest nodeClick
  click archive nodeClick
  click workbench nodeClick
  click digester nodeClick
  click digests nodeClick
  click selector nodeClick
  click selected nodeClick
  click assimilator nodeClick
  click kg nodeClick
  click synthesiser nodeClick
  click briefs nodeClick
  click assembler nodeClick
  click content nodeClick
  click site nodeClick
  click brand nodeClick
